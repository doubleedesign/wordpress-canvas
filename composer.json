{
	"name": "doubleedesign/wordpress-canvas",
	"type": "project",
	"version": "2.1.0",
	"homepage": "https://github.com/doubleedesign/wordpress-canvas",
	"authors": [
		{
			"name": "Leesa Ward",
			"email": "leesa@doubleedesign.com.au"
		}
	],
	"require": {
		"php": ">=8.4",
		"roots/wordpress": "^7.0",
		"composer/installers": "^2.0",
		"doubleedesign/comet-canvas-blocks": "dev-master",
		"doubleedesign/comet-plugin-blocks": "dev-master",
		"doubleedesign/comet-calendar": "dev-master",
		"doubleedesign/doublee-breadcrumbs": "dev-main",
		"doubleedesign/doublee-base-plugin": "dev-master",
		"doubleedesign/acf-advanced-image-field": "dev-master",
		"doubleedesign/doublee-tinymce": "dev-master",
		"doubleedesign/doublee-ninja-markup": "dev-master",
		"wpackagist-plugin/ninja-forms": "*",
		"wpackagist-plugin/autodescription": "*",
		"wpackagist-plugin/simply-disable-comments": "*",
		"wpackagist-plugin/google-site-kit": "*",
		"ext-libxml": "*",
		"ext-dom": "*"
	},
	"replace": {
		"doubleedesign/comet-components-core": "*"
	},
	"repositories": [
		{
			"name": "wpackagist",
			"type": "composer",
			"url": "https://wpackagist.org",
			"only": [
				"wpackagist-plugin/*",
				"wpackagist-theme/*"
			]
		},
		{
			"type": "vcs",
			"url": "https://github.com/doubleedesign/baguetteBox.js"
		},
		{
			"type": "vcs",
			"url": "https://github.com/doubleedesign/doublee-local-dev"
		}
	],
	"extra": {
		"installer-paths": {
			"app/wp-content/plugins/{$name}/": [
				"type:wordpress-plugin"
			],
			"app/wp-content/themes/{$name}/": [
				"type:wordpress-theme"
			]
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"roots/wordpress-core-installer": true
		},
		"optimize-autoloader": true
	},
	"scripts": {
		"post-update-cmd": [
			"pwsh.exe -NoProfile .\\postinstall.ps1"
		],
		"post-install-cmd": [
			"pwsh.exe -NoProfile .\\postinstall.ps1"
		]
	}
}
